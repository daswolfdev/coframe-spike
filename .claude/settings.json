{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/checks/claude-hook.sh edit",
            "timeout": 30,
            "statusMessage": "Convention gate (markdown edit)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/checks/claude-hook.sh stop",
            "timeout": 30,
            "statusMessage": "Convention gate (end of turn)"
          }
        ]
      }
    ]
  }
}
